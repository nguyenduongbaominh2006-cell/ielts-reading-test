    <style>
        :root {
            --primary-color: #0d5c75;
            --secondary-color: #f8fafc;
            --text-color: #1e293b;
            --border-color: #cbd5e1;
            --success-color: #16a34a;
            --danger-color: #dc2626;
            --highlight-color: #fef08a; /* Màu vàng bôi sáng chuẩn thi máy */
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        body {
            color: var(--text-color);
            background-color: #fff;
            height: 100vh;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        /* Overlays Layout */
        .overlay-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(255, 255, 255, 0.98);
            z-index: 9999;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .modal-box {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            max-width: 600px;
            width: 90%;
            text-align: center;
            border-top: 8px solid var(--primary-color);
        }

        .modal-box h1 {
            color: var(--primary-color);
            margin-bottom: 20px;
        }

        .modal-box p {
            margin: 10px 0;
            font-size: 16px;
        }

        .modal-box ul {
            text-align: left;
            margin: 20px 0;
            padding-left: 20px;
            line-height: 1.8;
        }

        .modal-box input {
            width: 100%;
            padding: 12px;
            margin: 20px 0;
            border: 1px solid var(--border-color);
            border-radius: 4px;
            font-size: 16px;
        }

        .btn-action {
            background: var(--primary-color);
            color: white;
            padding: 12px 30px;
            border: none;
            border-radius: 4px;
            font-size: 18px;
            cursor: pointer;
            font-weight: bold;
            transition: background 0.2s;
        }

        .btn-action:hover {
            background: #094356;
        }

        #score-screen {
            display: none;
            background: rgba(0, 0, 0, 0.6);
        }

        #score-screen .modal-box {
            border-top: 8px solid var(--success-color);
        }

        .score-highlight {
            font-size: 28px !important;
            font-weight: bold;
            color: var(--primary-color);
            margin: 15px 0 !important;
        }

        /* Header Components */
        header {
            background: var(--secondary-color);
            border-bottom: 1px solid var(--border-color);
            padding: 10px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 60px;
        }

        .test-title {
            font-weight: bold;
            color: var(--primary-color);
        }

        .header-controls {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .btn-submit {
            background: var(--danger-color);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        .btn-download {
            display: none;
            background: var(--success-color);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
        }

        /* Main Workspace Split Screen */
        .main-container {
            display: flex;
            flex: 1;
            overflow: hidden;
            position: relative;
        }

        .part-container {
            display: none;
            width: 100%;
            height: 100%;
        }

        .part-container.active {
            display: flex;
        }

        .passage-side {
            width: 50%;
            padding: 25px;
            overflow-y: auto;
            border-right: 2px solid var(--border-color);
            line-height: 1.7;
            background: #fff;
            position: relative;
        }

        .passage-side h2 {
            color: var(--primary-color);
            margin-bottom: 15px;
            font-size: 22px;
        }

        .passage-side p {
            margin-bottom: 18px;
            text-align: justify;
        }

        .question-side {
            width: 50%;
            padding: 25px;
            overflow-y: auto;
            background: #f8fafc;
            padding-bottom: 80px;
        }

        /* Highlight Style classes */
        .ielts-highlight {
            background-color: var(--highlight-color);
            cursor: pointer;
        }

        #highlight-menu {
            position: fixed;
            display: none;
            background: #1e293b;
            color: #fff;
